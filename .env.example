# OpenProject Integration
OP_API_URL=https://your-openproject.example.com/api/v3
OP_API_TOKEN=your_openproject_api_key_here

# Invoice Ninja Integration
# API URL for backend requests
IN_API_URL=https://your-invoice-ninja.example.com/api/v1
IN_API_TOKEN=your_invoice_ninja_api_key_here_starts_with_ninja_

# Application Auth
APP_LOGIN=admin
APP_PASSWORD=strong_password_here
JWT_SECRET=generate_a_long_random_string_here

# Infrastructure & Domains (No hardcoded URLs in frontend anymore)
BACKEND_PORT=8100
FRONTEND_PORT=5180

# CORS: URL of your frontend
CORS_ORIGINS=https://billing.example.com

# Frontend Environment Variables (Vite)
# The full URL of your backend API (visible to your browser)
VITE_API_BASE_URL=https://api.billing.example.com/api/v1
# The root URL of your Invoice Ninja installation (for links)
VITE_INVOICE_NINJA_BASE_URL=https://invoice.example.com
# Optional: Allowed hosts for the dev server (comma-separated, e.g., billing.example.com)
VITE_ALLOWED_HOSTS=billing.example.com

# Google Gemini API Key (optional for AI enrichment)
GEMINI_API_KEY=
